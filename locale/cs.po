# 
# File: usr/share/appimage-creator/utils/tooltip_helper.py, line: 39
#: NEEDS WORK
msgid ""
"The application name used for the AppImage filename and menu entry.\n"
"\n"
"Only letters, numbers, spaces, hyphens, underscores and dots are allowed."
msgstr ""
"Název aplikace používaný pro název souboru AppImage a položku v nabídce.\n"
"\n"
"Povoleny jsou pouze písmena, čísla, mezery, pomlčky, podtržítka a tečky."
# 
# File: usr/share/appimage-creator/utils/tooltip_helper.py, line: 43
#: NEEDS WORK
msgid ""
"The application icon is used in the system menu, taskbar, and file manager.\n"
"\n"
"A 256×256 or larger PNG/SVG icon is recommended.\n"
"\n"
"Without an icon, the AppImage will display a generic icon in menus and taskbar."
msgstr ""
"Ikona aplikace se používá v systémovém menu, na panelu úloh a v správci souborů.\n"
"\n"
"Doporučuje se ikona PNG/SVG o velikosti 256×256 nebo větší.\n"
"\n"
"Bez ikony se v menu a na panelu úloh zobrazí obecná ikona AppImage."
# 
# File: usr/share/appimage-creator/utils/tooltip_helper.py, line: 48
#: NEEDS WORK
msgid ""
"The .desktop file controls how the application appears in the system menu, including its name, "
"icon, categories, and launch options.\n"
"\n"
"If you don't provide one, a basic .desktop file will be generated automatically using the "
"information configured here.\n"
"\n"
"For full integration, provide your own file with proper categories and metadata."
msgstr ""
"Soubor .desktop řídí, jak se aplikace zobrazuje v systémovém menu, včetně jejího názvu, ikony, "
"kategorií a možností spuštění.\n"
"\n"
"Pokud jeden neposkytnete, bude automaticky vygenerován základní soubor .desktop pomocí zde "
"nakonfigurovaných informací.\n"
"\n"
"Pro plnou integraci poskytněte svůj vlastní soubor s odpovídajícími kategoriemi a metadaty."
# 
# File: usr/share/appimage-creator/utils/tooltip_helper.py, line: 55
#: NEEDS WORK
msgid ""
"Determines how the launcher (AppRun) script is generated.\n"
"\n"
"This is auto-detected from the executable, but you can override it:\n"
"• Binary — compiled native executable\n"
"• Python — Python script using system interpreter\n"
"• Electron — Electron-based application\n"
"• GTK/Qt — GUI applications with toolkit-specific environment variables"
msgstr ""
"Určuje, jak je generován spouštěcí skript (AppRun).\n"
"\n"
"Toto je automaticky detekováno z spustitelného souboru, ale můžete to přepsat:\n"
"• Binární — zkompilovaný nativní spustitelný soubor\n"
"• Python — Python skript používající systémový interpreter\n"
"• Electron — aplikace založená na Electronu\n"
"• GTK/Qt — GUI aplikace s proměnnými prostředí specifickými pro toolkit"
# 
# File: usr/share/appimage-creator/utils/tooltip_helper.py, line: 64
#: NEEDS WORK
msgid ""
"Semantic version of your application (e.g. 1.2.3).\n"
"\n"
"This is embedded in the AppImage metadata and used for update detection."
msgstr ""
"Sémantická verze vaší aplikace (např. 1.2.3).\n"
"\n"
"Toto je vloženo v metadatech AppImage a používá se pro detekci aktualizací."
# 
# File: usr/share/appimage-creator/utils/tooltip_helper.py, line: 68
#: NEEDS WORK
msgid ""
"A short one-line description shown in application menus and package managers.\n"
"\n"
"Keep it concise — typically under 80 characters."
msgstr "Krátký popis zobrazený v aplikačních nabídkách a správci balíčků."
# 
# File: usr/share/appimage-creator/utils/tooltip_helper.py, line: 72
#: NEEDS WORK
msgid ""
"Enable this for CLI tools that need a terminal to run.\n"
"\n"
"When enabled, the desktop environment will open a terminal emulator before launching the "
"application."
msgstr ""
"Povolte to pro nástroje CLI, které potřebují terminál k běhu.\n"
"\n"
"Když je to povoleno, desktopové prostředí otevře emulátor terminálu před spuštěním aplikace."
# 
# File: usr/share/appimage-creator/utils/tooltip_helper.py, line: 77
#: NEEDS WORK
msgid ""
"GitHub Releases API URL for automatic updates.\n"
"\n"
"Must start with https:// — typically:\n"
"https://api.github.com/repos/OWNER/REPO/releases/latest\n"
"\n"
"Click the paste button to insert a template."
msgstr ""
"API URL GitHub Releases pro automatické aktualizace. \n"
"\n"
"Musí začínat https:// — typicky: \n"
"https://api.github.com/repos/OWNER/REPO/releases/latest\n"
"\n"
"Klikněte na tlačítko vložit pro vložení šablony."
# 
# File: usr/share/appimage-creator/utils/tooltip_helper.py, line: 83
#: NEEDS WORK
msgid ""
"Glob pattern to identify which file to download from the release.\n"
"\n"
"The asterisk (*) matches any text. Examples:\n"
"• myapp-*-x86_64.AppImage\n"
"• *-gui-*.AppImage"
msgstr ""
"Globový vzor pro identifikaci, který soubor stáhnout z vydání.\n"
"\n"
"Hvězdička (*) odpovídá jakémukoli textu. Příklady:\n"
"• myapp-*-x86_64.AppImage\n"
"• *-gui-*.AppImage"
# 
# File: usr/share/appimage-creator/utils/tooltip_helper.py, line: 90
#: NEEDS WORK
msgid ""
"The directory where the final .AppImage file will be saved.\n"
"\n"
"Defaults to the current working directory."
msgstr ""
"Adresář, kde bude uložen finální soubor .AppImage.\n"
"\n"
"Ve výchozím nastavení se používá aktuální pracovní adresář."
# 
# File: usr/share/appimage-creator/utils/tooltip_helper.py, line: 94
#: NEEDS WORK
msgid ""
"Choose where to build the AppImage.\n"
"\n"
"Using a Distrobox container provides maximum compatibility with older Linux distributions, as it "
"builds against an older glibc."
msgstr "Vyberte místo pro vytvoření AppImage."
# 
# File: usr/share/appimage-creator/utils/tooltip_helper.py, line: 99
#: NEEDS WORK
msgid ""
"Bundle shared libraries (.so files) into the AppImage.\n"
"\n"
"This ensures the application works on other systems that may not have the required libraries "
"installed."
msgstr ""
"Sbalit sdílené knihovny (.so soubory) do AppImage.\n"
"\n"
"To zajišťuje, že aplikace funguje na jiných systémech, které nemusí mít nainstalovány požadované "
"knihovny."
# 
# File: usr/share/appimage-creator/utils/tooltip_helper.py, line: 104
#: NEEDS WORK
msgid ""
"Bundle an icon theme inside the AppImage.\n"
"\n"
"Without a bundled theme, some icons may be missing on desktops that use a different icon theme than "
"the one your app was designed for."
msgstr ""
"Zabalte ikonu téma do AppImage.\n"
"\n"
"Bez zabalného tématu mohou některé ikony chybět na plochách, které používají jinou ikonu téma, než "
"pro kterou byla vaše aplikace navržena."
# 
# File: usr/share/appimage-creator/utils/tooltip_helper.py, line: 109
#: NEEDS WORK
msgid ""
"Remove debug symbols from binaries to reduce the AppImage size.\n"
"\n"
"This makes the file smaller but harder to debug if issues occur."
msgstr ""
"Odstraňte ladicí symboly z binárních souborů, abyste snížili velikost AppImage.\n"
"\n"
"To zmenší soubor, ale ztíží ladění, pokud dojde k problémům."
